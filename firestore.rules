rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function ownsExistingDoc() {
      return isSignedIn() && resource.data.uid == request.auth.uid;
    }

    function ownsIncomingDoc() {
      return isSignedIn() && request.resource.data.uid == request.auth.uid;
    }

    match /users/{userId} {
      allow read, delete: if isUser(userId);
      allow create: if isUser(userId) && request.resource.data.uid == request.auth.uid;
      allow update: if isUser(userId)
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
    }

    match /farms/{farmId} {
      allow read, delete: if ownsExistingDoc();
      allow create: if ownsIncomingDoc();
      allow update: if ownsExistingDoc() && request.resource.data.uid == resource.data.uid;
    }

    match /farmDevices/{deviceId} {
      allow read, delete: if ownsExistingDoc();
      allow create: if ownsIncomingDoc();
      allow update: if ownsExistingDoc() && request.resource.data.uid == resource.data.uid;
    }

    match /soilProfiles/{soilId} {
      allow read, delete: if ownsExistingDoc();
      allow create: if ownsIncomingDoc();
      allow update: if ownsExistingDoc() && request.resource.data.uid == resource.data.uid;
    }

    match /weatherSnapshots/{weatherId} {
      allow read, delete: if ownsExistingDoc();
      allow create: if ownsIncomingDoc();
      allow update: if ownsExistingDoc() && request.resource.data.uid == resource.data.uid;
    }

    match /cropRecommendations/{recommendationId} {
      allow read, delete: if ownsExistingDoc();
      allow create: if ownsIncomingDoc();
      allow update: if ownsExistingDoc() && request.resource.data.uid == resource.data.uid;
    }

    match /yieldForecasts/{forecastId} {
      allow read, delete: if ownsExistingDoc();
      allow create: if ownsIncomingDoc();
      allow update: if ownsExistingDoc() && request.resource.data.uid == resource.data.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
