# ------------------------------------------------------------
# Public client configuration (safe for browser exposure)
# ------------------------------------------------------------
# Required for Firebase client SDK (Auth + browser app)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abcdef123456

# ------------------------------------------------------------
# Server-side secrets (never expose to client)
# ------------------------------------------------------------
# Required for Firebase Admin SDK (server route handlers)
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Required for Cloudinary profile image uploads
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Optional in this phase. Keep only if/when these providers are integrated.
OPENAI_API_KEY=your_openai_api_key
WEATHER_API_KEY=your_weather_api_key
GEOCODING_API_KEY=your_geocoding_api_key
SOIL_API_KEY=your_soil_api_key
MARKET_API_KEY=your_market_api_key
COMMODITY_API_KEY=your_rapidapi_commodity_key

# Optional provider endpoints
WEATHER_API_BASE_URL=https://api.example-weather.com
GEOCODING_API_BASE_URL=https://api.example-geocoding.com
SOIL_API_BASE_URL=https://api.example-soil.com
MARKET_API_BASE_URL=https://api.example-market.com
COMMODITY_API_BASE_URL=https://commodity-rates-api.p.rapidapi.com

# Password reset security
RESET_TOKEN_SECRET=change_me_to_a_long_random_secret

# Optional EmailJS integration for forgot-password emails
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_TEMPLATE_ID=your_emailjs_template_id
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_PRIVATE_KEY=your_emailjs_private_key
